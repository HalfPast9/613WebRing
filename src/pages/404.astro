---
import BaseLayout from "../layouts/BaseLayout.astro";
import RingMark from "../components/RingMark.astro";
---

<BaseLayout title="Lost in the ring" noindex>
  <section class="nf">
    <div class="container nf-inner">
      <span class="nf-mark"><RingMark size={56} /></span>
      <p class="nf-code chrome-text">404</p>
      <h1>You've wandered off the ring</h1>
      <p class="lead">
        This page isn't a stop on the 613 Webring. Let's get you back to
        Ottawa's builders.
      </p>
      <div class="nf-actions">
        <a class="btn btn-primary" href="/">Back to the ring</a>
        <a class="btn" href="/nav?dir=random">Hop somewhere random 🎲</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .nf {
    min-height: 64vh;
    display: grid;
    place-items: center;
    text-align: center;
    padding: 3rem 1rem;
  }
  .nf-mark {
    display: inline-flex;
    color: var(--accent);
  }
  .nf-code {
    font-family: var(--font-mono);
    font-weight: 700;
    font-size: clamp(3rem, 12vw, 5rem);
    color: var(--accent);
    line-height: 1;
    margin: 0.4rem 0;
  }
  .nf h1 {
    font-size: clamp(1.5rem, 5vw, 2.2rem);
    margin-bottom: 0.6rem;
  }
  .nf-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.7rem;
    justify-content: center;
    margin-top: 1.6rem;
  }
</style>
