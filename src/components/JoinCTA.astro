---
import OttawaSkyline from "./OttawaSkyline.astro";
import RingMark from "./RingMark.astro";
---

<section class="joincta-wrap section">
  <div class="container">
    <div class="joincta">
      <OttawaSkyline class="joincta-skyline" />
      <div class="joincta-inner">
        <span class="joincta-mark"><RingMark size={42} /></span>
        <h2 class="joincta-title">Build in Ottawa? Join the ring.</h2>
        <p class="joincta-lead">
          Whether you're shipping at a startup, studying at uOttawa, Carleton or
          Algonquin, or writing your very first lines of code — there's a node
          on this ring for you. It takes one pull request.
        </p>
        <div class="joincta-actions">
          <a class="btn btn-primary" href="/join">Add your site →</a>
          <a class="btn joincta-ghost" href="/#members">See who's in</a>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .joincta {
    position: relative;
    overflow: hidden;
    border-radius: var(--radius-lg);
    padding: clamp(2.5rem, 6vw, 4.5rem) clamp(1.5rem, 5vw, 4rem);
    text-align: center;
    color: #fff;
    background:
      radial-gradient(
        120% 120% at 50% -20%,
        rgba(255, 255, 255, 0.18),
        transparent 60%
      ),
      linear-gradient(
        135deg,
        var(--bco-red-deep),
        var(--bco-red) 45%,
        var(--canal-blue-deep)
      );
    box-shadow: var(--shadow-lg);
  }
  .joincta-skyline {
    position: absolute;
    inset: auto 0 0 0;
    height: 120px;
    width: 100%;
    color: #fff;
    opacity: 0.16;
    pointer-events: none;
  }
  .joincta-inner {
    position: relative;
    max-width: 56ch;
    margin-inline: auto;
  }
  .joincta-mark {
    display: inline-flex;
    color: #fff;
    margin-bottom: 0.6rem;
  }
  .joincta-title {
    color: #fff;
    font-size: clamp(1.8rem, 5vw, 2.8rem);
  }
  .joincta-lead {
    margin-top: 0.9rem;
    color: rgba(255, 255, 255, 0.9);
    font-size: clamp(1rem, 2.3vw, 1.15rem);
  }
  .joincta-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    justify-content: center;
    margin-top: 1.8rem;
  }
  .joincta .btn-primary {
    --btn-bg: #fff;
    --btn-fg: var(--bco-red-deep);
    --btn-bd: #fff;
  }
  .joincta .btn-primary:hover {
    --btn-bg: #fff;
    --btn-fg: var(--bco-red-deep);
    --btn-bd: #fff;
  }
  .joincta-ghost {
    --btn-bg: transparent;
    --btn-fg: #fff;
    --btn-bd: rgba(255, 255, 255, 0.6);
    backdrop-filter: blur(4px);
  }
  .joincta-ghost:hover {
    --btn-bd: #fff;
  }
</style>
