---
/**
 * A stylised Ottawa skyline silhouette: the Parliament Buildings with the
 * Peace Tower at centre and the round Library of Parliament to the right.
 * Decorative only (aria-hidden). Colour via `currentColor`.
 */
interface Props {
  class?: string;
}
const { class: className } = Astro.props;
---

<svg
  class={className}
  viewBox="0 0 1200 200"
  preserveAspectRatio="xMidYMax meet"
  fill="currentColor"
  aria-hidden="true"
  xmlns="http://www.w3.org/2000/svg"
>
  <!-- left wing buildings -->
  <rect x="40" y="140" width="90" height="60"></rect>
  <rect x="60" y="120" width="14" height="20"></rect>
  <rect x="100" y="118" width="14" height="22"></rect>
  <rect x="150" y="125" width="120" height="75"></rect>
  <polygon points="150,125 210,95 270,125"></polygon>
  <rect x="205" y="80" width="10" height="25"></rect>

  <!-- inner left block -->
  <rect x="300" y="135" width="150" height="65"></rect>
  <rect x="330" y="110" width="18" height="25"></rect>
  <rect x="400" y="108" width="18" height="27"></rect>

  <!-- Peace Tower (centre) -->
  <rect x="540" y="70" width="120" height="130"></rect>
  <polygon points="540,70 600,18 660,70"></polygon>
  <rect x="592" y="0" width="16" height="22"></rect>
  <rect x="597" y="-14" width="6" height="16"></rect>
  <!-- clock face -->
  <circle cx="600" cy="92" r="15" fill="var(--bg)"></circle>
  <circle
    cx="600"
    cy="92"
    r="15"
    fill="none"
    stroke="currentColor"
    stroke-width="3"></circle>
  <rect x="599" y="82" width="2.5" height="11"></rect>
  <rect x="600" y="91" width="9" height="2.5"></rect>
  <!-- base flanks -->
  <rect x="500" y="150" width="40" height="50"></rect>
  <rect x="660" y="150" width="40" height="50"></rect>

  <!-- right wing buildings -->
  <rect x="730" y="138" width="150" height="62"></rect>
  <polygon points="730,138 800,108 870,138"></polygon>
  <rect x="795" y="92" width="10" height="20"></rect>

  <!-- Library of Parliament (round) -->
  <path d="M935 200 V150 a70 70 0 0 1 140 0 V200 Z"></path>
  <polygon points="935,150 1005,108 1075,150"></polygon>
  <rect x="1000" y="92" width="10" height="18"></rect>

  <!-- far right -->
  <rect x="1110" y="150" width="60" height="50"></rect>
  <rect x="1128" y="130" width="12" height="20"></rect>
</svg>
