---
/**
 * The 613 Webring mark: nodes linked in a ring. Inherits `currentColor`,
 * so colour it from the parent. Used in the nav wordmark, favicon and widget.
 */
interface Props {
  size?: number;
  class?: string;
}
const { size = 28, class: className } = Astro.props;

// Six nodes evenly placed on a circle of radius 38 (viewBox 100x100, centre 50).
const nodes = Array.from({ length: 6 }, (_, i) => {
  const a = (Math.PI / 3) * i - Math.PI / 2;
  return { x: 50 + 38 * Math.cos(a), y: 50 + 38 * Math.sin(a) };
});
---

<svg
  class={className}
  width={size}
  height={size}
  viewBox="0 0 100 100"
  fill="none"
  role="img"
  aria-label="613 Webring"
  xmlns="http://www.w3.org/2000/svg"
>
  <circle
    cx="50"
    cy="50"
    r="38"
    stroke="currentColor"
    stroke-width="4"
    opacity="0.35"></circle>
  {nodes.map((n) => <circle cx={n.x} cy={n.y} r="8" fill="currentColor" />)}
  <circle cx="50" cy="50" r="6" fill="currentColor" opacity="0.55"></circle>
</svg>
